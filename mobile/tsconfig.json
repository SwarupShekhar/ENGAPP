{
  "compilerOptions": {
    "strict": true,
    "resolveJsonModule": true,
    "jsx": "react-native",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "target": "ES2020",
    "module": "ESNext",
    "skipLibCheck": true,
    "lib": [
      "ES2020",
      "DOM"
    ],
    "types": [
      "react"
    ],
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "app/**/*"
  ],
  "extends": "expo/tsconfig.base"
}
