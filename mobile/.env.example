# Copy to `.env` for local dev (gitignored). EAS builds: set secrets in Expo dashboard.
#
# ─── Three backends (Option A) ───────────────────────────────────────────────
# Same Clerk app for EngR + Englivo — one sign-in, one JWT on all clients.
#
# 1) EngR / Pulse (Nest) — matchmaking, P2P calls, Maya tutor, home feed
#    EXPO_PUBLIC_NEST_API_URL=https://your-vultr-host:4001
#    (or APP_API_URL_OVERRIDE in app.config.js)
#
# 2) Englivo tab — human tutor, quota, booking (NOT Nest)
#    Default production: https://englivo.com
#    APP_ENGLIVO_API_URL=https://englivo.com
#
# 3) Bridge — shared CEFR, streak, practice minutes across modes
#    Default: https://bridge-api-3m4n.onrender.com
#    BRIDGE_INTERNAL_SECRET=<matches Bridge INTERNAL_SECRET>
#    APP_BRIDGE_API_URL=...
#
# ─── Metro / dev client ───────────────────────────────────────────────────────
# Tunnel: npm run start:dev:tunnel
# LAN:    REACT_NATIVE_PACKAGER_HOSTNAME=192.168.x.x npm run start:dev
#
# EAS Internal: set BRIDGE_INTERNAL_SECRET in Expo → Secrets (build-time).

BRIDGE_INTERNAL_SECRET=

# Optional overrides (see app.config.js / expo extra)
# EXPO_PUBLIC_NEST_API_URL=http://192.168.x.x:3004
# APP_API_URL_OVERRIDE=http://192.168.x.x:3004
# APP_ENGLIVO_API_URL=https://englivo.com
# APP_BRIDGE_API_URL=https://bridge-api-3m4n.onrender.com
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Sentry (mobile — same org as Vultr backends; use a dedicated mobile project DSN)
# EXPO_PUBLIC_SENTRY_DSN=https://…@….ingest.sentry.io/…
# EXPO_PUBLIC_SENTRY_ENVIRONMENT=internal
# EAS source maps (optional): SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN secret

# PostHog
# EXPO_PUBLIC_POSTHOG_API_KEY=phc_…
# EXPO_PUBLIC_POSTHOG_SESSION_REPLAY=true
