# Application
APP_NAME=englivo-ai-engine
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8001
WORKERS=4

# API Keys
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_STORAGE_CONNECTION_STRING=

# Database
# Vultr host Postgres from Docker: postgresql+asyncpg://user:pass@host.docker.internal:4011/neondb
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/englivo

# Redis — must match backend-nest (coaching context is shared via coaching:{userId}:{sessionId})
# Production (Upstash/Redis Cloud): use the same URL/credentials as backend-nest REDIS_* vars
REDIS_URL=redis://localhost:6379/0
# Optional legacy host/port (only used when REDIS_URL is unset)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_USERNAME=default
# REDIS_PASSWORD=
REDIS_CACHE_TTL=3600

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Caching
ENABLE_CACHE=true
# Local CPU TTS (Kitten mini 0.8) for daily phrase/word + static Maya acks
KITTEN_TTS_ENABLED=true
CACHE_TTL_TRANSCRIPTION=86400
CACHE_TTL_ANALYSIS=3600
CACHE_TTL_PRONUNCIATION=7200
DISK_CACHE_DIR=/tmp/englivo-cache

# Cerebras Inference (Maya tutor smoke / optional fast LLM — feat/cerebras-maya-llm branch)
# CEREBRAS_API_KEY=
# CEREBRAS_CHAT_MODEL=gpt-oss-120b
# CEREBRAS_MAX_COMPLETION_TOKENS=220
# MAYA_LLM_PROVIDER=auto
# MAYA_LLM_FALLBACK_TO_GEMINI=true
# COACHING_LLM_PROVIDER=auto
# COACHING_CEREBRAS_MODEL=gemma-4-31b
# COACHING_HINT_BUDGET_MS=900

# Google Gemini (Maya tutor chat — gemini-2.0-* retired 2026-06-01)
# GOOGLE_GEMINI_CHAT_MODEL=gemini-2.5-flash
TRANSCRIPTION_MODEL=azure
ANALYSIS_MODEL=gemini
PRONUNCIATION_MODEL=azure
CEFR_MODEL=custom
TTS_PROVIDER=inworld
DISABLE_AZURE_TTS=true

# Fish Audio TTS — primary for /api/tts/speak (daily listen + lookup); Inworld fallback
# FISH_AUDIO_API_KEY=
# FISH_TTS_ENABLED=true
# FISH_TTS_MODEL=s2.1-pro-free
# FISH_TTS_TIMEOUT_SEC=12
# Optional voice model ids from https://fish.audio (map daily Kiki/Jasper)
# FISH_TTS_REFERENCE_ID=
# FISH_TTS_REFERENCE_ID_KIKI=
# FISH_TTS_REFERENCE_ID_JASPER=

# Deepgram (optional — off by default; Azure is primary STT for tutor + calls)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en-IN
DEEPGRAM_PRIMARY_STT=false
DEEPGRAM_SECONDARY_TRANSCRIPT=false

# Phonemizer / espeak-ng shared library (Layer 2 non-dictionary words). Required on many macOS setups.
# Example (Apple Silicon Homebrew): /opt/homebrew/lib/libespeak-ng.1.dylib
# Example (Debian/Ubuntu after apt install espeak-ng): /usr/lib/x86_64-linux-gnu/libespeak-ng.so
# Docker (Dockerfile in this folder): leave unset locally — the image sets it at startup from installed libespeak-ng.
PHONEMIZER_ESPEAK_LIBRARY=

# Feature Flags
ENABLE_PRONUNCIATION_SCORING=true
ENABLE_CEFR_CLASSIFICATION=true
ENABLE_ERROR_TAGGING=true

# Debug logging for pronunciation internals (DO NOT enable in production)
# PRON_DEBUG=0

# Security
INTERNAL_API_KEY=your_secret_key_for_nest_backend
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Monitoring
SENTRY_DSN=
ENABLE_PROMETHEUS=true

# OpenTelemetry → Grafana Cloud (same stack as backend-nest)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-south-1.grafana.net/otlp
# GRAFANA_INSTANCE_ID=1692905
# GRAFANA_CLOUD_API_KEY=glc_...
# OTEL_SERVICE_NAME=engr-backend-ai
# OTEL_SDK_DISABLED=true

# Tutor streaming (Phase 2.1) — bounded PA wait + concurrency cap on Vultr
# Maya tutor latency: 0 = start Gemini immediately; PA still runs in background for capture.
PA_STREAM_WAIT_MS=0
# Coaching hints: seconds before first hint; lower = faster in Maya tutor.
COACHING_WARMUP_SECONDS=5
# Max ms to wait for coaching hint LLM before starting Maya reply (parallel with PA wait).
COACHING_HINT_BUDGET_MS=150
# Optional: DEEPGRAM_PRIMARY_STT=true cuts STT from ~2s to ~300ms (Azure still used for PA).
PA_ENRICH_MAX_CONCURRENT=8

# Audio
MAX_AUDIO_SIZE_MB=50
SUPPORTED_AUDIO_FORMATS=wav,mp3,m4a,ogg,flac
AUDIO_SAMPLE_RATE=16000

# CEFR Thresholds
CEFR_A1_MAX_SCORE=30
CEFR_A2_MAX_SCORE=45
CEFR_B1_MAX_SCORE=60
CEFR_B2_MAX_SCORE=75
CEFR_C1_MAX_SCORE=90
