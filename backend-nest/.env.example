# Application Configuration
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.example.com

# Database (Neon Postgres — managed, external)
# Replace with your actual Neon connection string (uses host with "-pooler" suffix for app traffic)
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"
# For migrations: use direct (non-pooler) host to avoid advisory lock timeouts
DIRECT_URL="postgresql://user:password@host/neondb?sslmode=require"

# Redis (separate from Neon — managed service or local Docker)
# Local Docker Compose: REDIS_HOST=redis, REDIS_PORT=6379
# Managed (Upstash/Redis Cloud): use your host/port/credentials
REDIS_HOST="your-redis-host.upstash.io"
REDIS_PORT=6379
REDIS_USERNAME="default"
REDIS_PASSWORD="your-password"
# Some setups may use REDIS_URL instead (e.g., redis://:password@host:6379/0)

# Clerk Authentication
CLERK_SECRET_KEY="sk_..."
CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# Mux Video/Audio Services
MUX_TOKEN_ID="..."
MUX_TOKEN_SECRET="..."

# LiveKit Real-time Communication
LIVEKIT_URL="your_livekit_url_here"
LIVEKIT_HOST="https://your-project.livekit.cloud"
LIVEKIT_API_KEY="..."
LIVEKIT_API_SECRET="..."
LIVEKIT_EGRESS_AZURE_CONTAINER=recordings

# AWS S3 (for audio file storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID="your_aws_access_key_here"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key_here"
S3_BUCKET_NAME=engr-app-audio

# Python AI Engine (backend-ai — STT/TTS/pronunciation/transcription)
# In production, set to public HTTPS URL of backend-ai service
# In docker-compose.prod.yml we use the internal hostname:
# AI_ENGINE_URL=http://backend-ai:8001
AI_ENGINE_URL=http://backend-ai:8001
# Optional timeout for startup/periodic ping (ms); default 25000
# AI_ENGINE_HEALTH_TIMEOUT_MS=45000
# Secondary FastAPI client — must match AI_ENGINE_URL host/port
FASTAPI_SERVICE_URL=http://backend-ai:8001

# Logging
LOG_LEVEL=debug

# Push notifications (Pushy — https://dashboard.pushy.me/)
# Code accepts PUSHY_API_KEY (preferred) or PUSHY_ME_API_KEY (legacy name on some servers).
PUSHY_API_KEY=

# Monitoring
SENTRY_DSN=
