# Application Configuration
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.example.com

# Database (Neon or Vultr host Postgres)
# Neon: sslmode=require. Vultr Docker: host.docker.internal:4011 (needs extra_hosts in docker-compose.prod.yml)
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"
# For migrations: use direct (non-pooler) host to avoid advisory lock timeouts
DIRECT_URL="postgresql://user:password@host/neondb?sslmode=require"

# Redis (separate from Neon — managed service or local Docker)
# Local Docker Compose: REDIS_HOST=redis, REDIS_PORT=6379
# Managed (Upstash/Redis Cloud): use your host/port/credentials
REDIS_HOST="your-redis-host.upstash.io"
REDIS_PORT=6379
REDIS_USERNAME="default"
REDIS_PASSWORD="your-password"
# Some setups may use REDIS_URL instead (e.g., redis://:password@host:6379/0)

# PostHog (optional — server-side capture for push delivery, etc.)
# Use the project API key (phc_…), same project as mobile EXPO_PUBLIC_POSTHOG_API_KEY
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Clerk Authentication
CLERK_SECRET_KEY="sk_..."
CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# Mux Video/Audio Services
MUX_TOKEN_ID="..."
MUX_TOKEN_SECRET="..."

# LiveKit Real-time Communication
LIVEKIT_URL="your_livekit_url_here"
LIVEKIT_HOST="https://your-project.livekit.cloud"
LIVEKIT_API_KEY="..."
LIVEKIT_API_SECRET="..."
LIVEKIT_EGRESS_AZURE_CONTAINER=recordings

# AWS S3 (for audio file storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID="your_aws_access_key_here"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key_here"
S3_BUCKET_NAME=engr-app-audio

# Python AI Engine (backend-ai — STT/TTS/pronunciation/transcription)
# In production, set to public HTTPS URL of backend-ai service
# In docker-compose.prod.yml we use the internal hostname:
# AI_ENGINE_URL=http://backend-ai:8001
AI_ENGINE_URL=http://backend-ai:8001
# Shared secret for Nest → backend-ai HTTP (x-api-key) and metrics scraping.
# Must match INTERNAL_API_KEY in backend-ai/.env
INTERNAL_API_KEY=change-me-in-production
# Optional timeout for startup/periodic ping (ms); default 25000
# AI_ENGINE_HEALTH_TIMEOUT_MS=45000
# Secondary FastAPI client — must match AI_ENGINE_URL host/port
FASTAPI_SERVICE_URL=http://backend-ai:8001

# Logging
LOG_LEVEL=debug

# Push notifications (Firebase Cloud Messaging)
# Local: copy service account JSON to config/firebase-service-account.json
# Render/production: set FIREBASE_SERVICE_ACCOUNT_JSON to the full JSON string
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Monitoring
SENTRY_DSN=
# Optional: separate token for external Prometheus scrapes (defaults to INTERNAL_API_KEY)
# METRICS_SCRAPE_TOKEN=

# OpenTelemetry → Grafana Cloud (traces + RED metrics in Application Observability)
# Portal: Grafana Cloud → your stack → OpenTelemetry (NOT "Private connectivity" on Vultr)
# Public gateway (ap-south-1 — copy exact URL from your stack):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-south-1.grafana.net/otlp
# Auth option A — paste the Base64 token Grafana shows on the OpenTelemetry page:
# GRAFANA_OTLP_TOKEN=
# Auth option B — instance ID + OTLP access policy token (glc_...):
# GRAFANA_INSTANCE_ID=
# GRAFANA_CLOUD_API_KEY=
# OTEL_SERVICE_NAME=engr-backend-nest
# OTEL_SDK_DISABLED=true
# Optional: OTEL_METRIC_EXPORT_INTERVAL_MS=60000
# Do NOT use .vpce.grafana.net on Vultr — that is AWS PrivateLink only.

# REST rate limiting (@nestjs/throttler — per Clerk user or IP)
# THROTTLE_ENABLED=true
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=120
# THROTTLE_MATCHMAKING_LIMIT=30

# Bull session analysis queues (split P2P vs Maya)
# BULL_SESSIONS_P2P_CONCURRENCY=3
# BULL_SESSIONS_MAYA_CONCURRENCY=2

# Maya tutor in-flight session state (Redis key maya:session:{id})
# MAYA_SESSION_TTL_SEC=14400
# MAYA_ORPHAN_GRACE_SEC=14400

# Strapi reels feed cache (Redis L2 + in-memory L1; warm on startup)
# STRAPI_FEED_CACHE_TTL_SEC=3600
# REELS_FEED_CACHE_TTL_SEC=300

# Artillery Phase 0 smoke (scripts/load/run-artillery-smoke.mjs)
# ARTILLERY_CLOUD_API_KEY=...   # or ARTILLERY_API_KEY (runner maps both)
# ARTILLERY_NEST_TARGET=https://api.englivo.com
# ARTILLERY_AI_TARGET=http://139.84.163.249:4002
# ARTILLERY_CLERK_BEARER_TOKEN=eyJ...   # for npm run load:breakpoint:read
# ARTILLERY_CLERK_BEARER_TOKEN_2=eyJ... # optional second test user
