# Application Configuration
PORT=3002
NODE_ENV=development
FRONTEND_URL=http://localhost:3002

# Database Configuration
# Use pooler URL for app runtime (Neon: host contains "-pooler")
DATABASE_URL="postgresql://swarupshekhar:171199@localhost:5432/engr_app"
# For Neon: use direct (non-pooler) URL for migrations to avoid advisory lock timeouts.
# Same as DATABASE_URL but host without "-pooler" (e.g. ep-xxx.eastus2.azure.neon.tech).
DIRECT_URL="postgresql://swarupshekhar:171199@localhost:5432/engr_app"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Clerk Configuration
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# LiveKit Configuration
LIVEKIT_URL=your_livekit_url_here
LIVEKIT_HOST=https://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
LIVEKIT_EGRESS_AZURE_CONTAINER=recordings

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
S3_BUCKET_NAME=engr-app-audio

# FastAPI Service Configuration (legacy analyze/transcribe client)
FASTAPI_SERVICE_URL=http://localhost:8000

# Python AI engine (tutor STT/TTS/stream, pronunciation, transcription) — REQUIRED on Render
# Must be public HTTPS URL of backend-ai (not localhost)
AI_ENGINE_URL=http://localhost:8001
# Optional: ms for startup/periodic ping to AI (Render cold start; default 25000)
# AI_ENGINE_HEALTH_TIMEOUT_MS=45000

# Logging Configuration
LOG_LEVEL=debug