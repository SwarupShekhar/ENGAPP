{
	# Uncomment and set your email when you have a real domain (for Let's Encrypt):
	# email you@example.com
}

# Listens on container port 80; docker-compose.prod.yml maps host :4008 -> :80.
# appapk.englivo.com → host :4003 (tester-portal service), not this Caddy.
# Public: http://<vultr-ip>:4008  (or proxy api.englivo.com -> 127.0.0.1:4008)
# For TLS on a domain, use a host reverse proxy or map 443 and set the site block to your domain.
:80 {
	# SSE tutor stream must not be gzip-buffered (adds seconds of latency).
	@sse path /conversational-tutor/stream-speech

	handle @sse {
		reverse_proxy backend-nest:3000 {
			flush_interval -1
			transport http {
				versions 1.1
			}
		}
	}

	# Maya WS fallback over the public HTTPS domain (wss://api.englivo.com/ai/...).
	# Strip /ai so backend-ai still sees /api/tutor/ws/{sessionId}.
	# Do NOT expose the rest of backend-ai externally — only this WS path.
	@aiTutorWs path /ai/api/tutor/ws/*
	handle @aiTutorWs {
		uri strip_prefix /ai
		reverse_proxy backend-ai:8001
	}

	handle {
		encode gzip

		header {
			-Server
			X-Content-Type-Options nosniff
			X-Frame-Options DENY
			Referrer-Policy no-referrer
		}

		# Default traffic → NestJS. backend-ai stays internal except @aiTutorWs above.
		reverse_proxy backend-nest:3000
	}
}
