{
	# Uncomment and set your email when you have a real domain (for Let's Encrypt):
	# email you@example.com
}

# IP-only access on port 80 (no TLS required — works without a domain).
# Once you have a real domain, replace ":80" with "api.yourdomain.com" and
# uncomment the email line above for automatic HTTPS via Let's Encrypt.
:80 {
	encode gzip

	header {
		-Server
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
	}

	# All traffic → NestJS; backend-ai is never exposed externally.
	reverse_proxy backend-nest:3000
}
