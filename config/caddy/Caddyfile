{
	# Uncomment and set your email when you have a real domain (for Let's Encrypt):
	# email you@example.com
}

# Listens on container port 80; docker-compose.prod.yml maps host :4008 -> :80.
# Public: http://<vultr-ip>:4008  (or proxy api.englivo.com -> 127.0.0.1:4008)
# For TLS on a domain, use a host reverse proxy or map 443 and set the site block to your domain.
:80 {
	# SSE tutor stream must not be gzip-buffered (adds seconds of latency).
	@sse path /conversational-tutor/stream-speech

	handle @sse {
		reverse_proxy backend-nest:3000 {
			flush_interval -1
			transport http {
				versions 1.1
			}
		}
	}

	handle {
		encode gzip

		header {
			-Server
			X-Content-Type-Options nosniff
			X-Frame-Options DENY
			Referrer-Policy no-referrer
		}

		# All traffic → NestJS; backend-ai is never exposed externally.
		reverse_proxy backend-nest:3000
	}
}
