# Serves appapk.englivo.com on host port 4003 (docker-compose.prod.yml).
:80 {
	root * /srv/site
	encode gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
	}

	@app_apk path /app-release.apk
	handle @app_apk {
		root * /srv/apk
		header Content-Type application/vnd.android.package-archive
		header Content-Disposition "attachment; filename=englivo-internal.apk"
		file_server
	}

	handle {
		file_server
	}
}
